import { apiClient } from "./apiClient.js";

export const getTasksApi = async (token, params) => {
  const { data } = await apiClient(token).get("/api/tasks", { params });
  return data;
};

export const createTaskApi = async (token, payload) => {
  const { data } = await apiClient(token).post("/api/tasks", payload);
  return data;
};

export const updateTaskApi = async (token, id, payload) => {
  const { data } = await apiClient(token).put(`/api/tasks/${id}`, payload);
  return data;
};

export const deleteTaskApi = async (token, id) => {
  const { data } = await apiClient(token).delete(`/api/tasks/${id}`);
  return data;
};

